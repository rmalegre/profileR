---
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = {
  name: "Rodrigo Alegre",
  title: "Desarrollador Full Stack",
  location: "Ciudad de México, México",
  email: "rodrigo@ejemplo.com",
  phone: "+52 123 456 7890",
  summary: "Desarrollador Full Stack con más de 5 años de experiencia en la creación de aplicaciones web modernas y escalables. Apasionado por la tecnología, el código limpio y la experiencia de usuario.",
};

const experience = [
  {
    company: "Tech Solutions S.A.",
    position: "Desarrollador Full Stack Senior",
    period: "2021 - Presente",
    description: "Liderazgo en el desarrollo de aplicaciones web usando React, Node.js y GraphQL. Implementación de arquitecturas escalables y optimización de rendimiento.",
  },
  {
    company: "Digital Agency",
    position: "Desarrollador Frontend",
    period: "2019 - 2021",
    description: "Desarrollo de interfaces de usuario responsivas y accesibles usando React, Vue.js y Astro. Colaboración con equipos de diseño para implementar pixel-perfect designs.",
  },
  {
    company: "Startup Innovadora",
    position: "Desarrollador Junior",
    period: "2017 - 2019",
    description: "Desarrollo full-stack con JavaScript, HTML5, CSS3 y PHP. Mantenimiento de bases de datos MySQL y PostgreSQL.",
  },
];

const education = [
  {
    institution: "Universidad Nacional Autónoma de México",
    degree: "Ingeniería en Sistemas Computacionales",
    period: "2013 - 2017",
  },
  {
    institution: "Platzi",
    degree: "Desarrollo Web Full Stack",
    period: "2018",
  },
];

const skills = [
  "JavaScript / TypeScript",
  "React / Next.js",
  "Astro",
  "Node.js",
  "GraphQL / REST API",
  "PostgreSQL / MongoDB",
  "Docker / AWS",
  "Git / CI/CD",
];
---

<BaseLayout title="Sobre Mí - Rodrigo Alegre">
  <main class="about">
    <section class="profile">
      <div class="profile-header">
        <div class="avatar">
          <span>RA</span>
        </div>
        <div class="profile-info">
          <h1>{profile.name}</h1>
          <p class="title">{profile.title}</p>
          <p class="location">{profile.location}</p>
          <div class="contact">
            <a href={`mailto:${profile.email}`}>{profile.email}</a>
            <span>•</span>
            <span>{profile.phone}</span>
          </div>
        </div>
        <a href="/cv-rodrigo-alegre.pdf" download class="btn-download">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Descargar CV
        </a>
      </div>
    </section>

    <section class="section">
      <h2>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Perfil Profesional
      </h2>
      <p class="summary">{profile.summary}</p>
    </section>

    <section class="section">
      <h2>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Experiencia Laboral
      </h2>
      <div class="timeline">
        {experience.map((exp) => (
          <div class="timeline-item">
            <div class="timeline-header">
              <h3>{exp.position}</h3>
              <span class="period">{exp.period}</span>
            </div>
            <p class="company">{exp.company}</p>
            <p class="description">{exp.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        Educación
      </h2>
      <div class="education">
        {education.map((edu) => (
          <div class="education-item">
            <h3>{edu.degree}</h3>
            <p class="institution">{edu.institution}</p>
            <span class="period">{edu.period}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5Z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        Habilidades
      </h2>
      <div class="skills-grid">
        {skills.map((skill) => (
          <span class="skill-tag">{skill}</span>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about {
    max-width: 800px;
    margin: 4rem auto 0; /* top margin to clear fixed navbar */
    padding: 0 1rem;
  }

  .profile {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .profile-info {
    flex: 1;
    min-width: 200px;
  }

  .profile-info h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
    background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .title {
    font-size: 1.2rem;
    color: #0072ff;
    margin-bottom: 0.5rem;
  }

  .location {
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .contact {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #666;
    flex-wrap: wrap;
  }

  .contact a {
    color: #00c6ff;
    text-decoration: none;
  }

  .contact a:hover {
    text-decoration: underline;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
    color: white;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-download:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 198, 255, 0.3);
    text-decoration: none;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
    color: #e0e0e0;
  }

  .section h2 svg {
    color: #00c6ff;
  }

  .summary {
    line-height: 1.8;
    color: #aaa;
    font-size: 1.05rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .timeline-item:hover {
    border-color: rgba(0, 198, 255, 0.2);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .timeline-header h3 {
    font-size: 1.1rem;
    color: #e0e0e0;
  }

  .period {
    font-size: 0.85rem;
    color: #0072ff;
    background: rgba(0, 114, 255, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  .company {
    color: #00c6ff;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .description {
    color: #888;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .education {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .education-item {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .education-item h3 {
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .institution {
    color: #00c6ff;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .education-item .period {
    font-size: 0.8rem;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .skill-tag {
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(0, 198, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    color: #ccc;
    transition: all 0.2s;
  }

  .skill-tag:hover {
    background: rgba(0, 198, 255, 0.1);
    border-color: #00c6ff;
    color: #00c6ff;
  }

  @media (max-width: 600px) {
    .profile-header {
      flex-direction: column;
      text-align: center;
    }

    .btn-download {
      width: 100%;
      justify-content: center;
    }

    .timeline-header {
      flex-direction: column;
    }
  }
</style>
