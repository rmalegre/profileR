---
import Navbar from "../components/Navbar.astro";
import SocialLinks from "../components/SocialLinks.astro";
import WhatsappFloat from "../components/WhatsappFloat.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: system-ui, -apple-system, sans-serif;
        background: linear-gradient(135deg, #0a0e27 0%, #16213e 100%);
        color: #e0e0e0;
      }

      body {
        /* ensure content sits below the fixed navbar; increase top padding if navbar grows */
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10rem 2rem 2rem; /* bumped from 8rem to give extra space */
      }

      h1 {
        font-size: 3.5rem;
        background: linear-gradient(135deg, #00c6ff 0%, #0072ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 2rem;
        text-shadow: 0 4px 20px rgba(0, 198, 255, 0.3);
        font-weight: 800;
      }

      .rocket {
        display: inline-block;
        animation: zoom 3s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% {
          transform: translateY(0px);
        }
        50% {
          transform: translateY(-20px);
        }
      }

      @keyframes zoom {
        0% {
          transform: scale(0.8) translateY(0px);
          filter: blur(0.5px) opacity(0.8);
        }
        50% {
          transform: scale(1) translateY(-10px);
          filter: blur(0px) opacity(1);
        }
        100% {
          transform: scale(1.15) translateY(-20px);
          filter: blur(0px) opacity(1);
        }
      }

      @keyframes explosion {
        0% {
          width: 0;
          height: 0;
          opacity: 1;
          box-shadow: 0 0 0 0 rgba(0, 198, 255, 0.8),
              0 0 0 0 rgba(255, 140, 66, 0.6);
        }
        50% {
          box-shadow: 0 0 40px 40px rgba(0, 198, 255, 0.5),
              0 0 80px 80px rgba(255, 140, 66, 0.2);
        }
        100% {
          width: 200px;
          height: 200px;
          opacity: 0;
          box-shadow: 0 0 80px 120px rgba(0, 198, 255, 0),
              0 0 120px 200px rgba(255, 140, 66, 0);
        }
      }

      @keyframes flashburst {
        0% {
          background: rgba(255, 200, 100, 0);
        }
        10% {
          background: rgba(255, 200, 100, 0.4);
        }
        20% {
          background: rgba(255, 255, 255, 0.2);
        }
        100% {
          background: rgba(255, 200, 100, 0);
        }
      }

      @keyframes sparkle {
        0% {
          transform: translateY(0) scale(1);
          opacity: 1;
        }
        100% {
          transform: translateY(-150px) scale(0);
          opacity: 0;
        }
      }

      .explosion-burst {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
        animation: explosion 2s ease-out forwards;
        z-index: 10;
      }

      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        animation: flashburst 1.5s ease-out forwards;
        z-index: 5;
      }

      .sparkle {
        position: fixed;
        pointer-events: none;
        font-size: 1.5rem;
        animation: sparkle 1.5s ease-out forwards;
        z-index: 8;
      }

      div {
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid rgba(0, 198, 255, 0.2);
        border-radius: 12px;
        padding: 2rem;
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        max-width: 600px;
        width: 100%;
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2rem;
        }

        div {
          padding: 1.5rem;
        }
      }

      a {
        color: #0072ff;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      p {
        line-height: 1.8;
        margin-bottom: 1rem;
      }

      code {
        background: rgba(0, 198, 255, 0.1);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        font-family: monospace;
      }
    </style>
  </head>
  <body>
    <Navbar />
    <slot />
    <SocialLinks />
    <WhatsappFloat />
  </body>
</html>
